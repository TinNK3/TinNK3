# ==============================
# GitHub Profile 3D Contrib — ENV
# ==============================

# Required
GITHUB_TOKEN=ghp_your_personal_access_token_here
USERNAME=TinNK3

# Optional
MAX_REPOS=100
GITHUB_ENDPOINT=https://api.github.com/graphql
YEAR=2026

# ==============================
# Real-time webhook (api/github-webhook.js) — set these in Vercel
# ==============================
# Secret shared with the GitHub App webhook (used to verify HMAC signatures).
WEBHOOK_SECRET=generate_a_long_random_string
# Which repo's workflow to trigger (defaults shown).
OWNER=TinNK3
REPO=TinNK3
